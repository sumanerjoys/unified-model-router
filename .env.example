# --- Unified Model Router: environment configuration ---
# Copy to `.env` and fill in real values. NEVER commit the real .env.

# Gateway auth (extension: API Authorization Guard). Comma-separated allowed keys.
# Leave empty to disable the guard. When set, callers must present a matching key
# via `Authorization: Bearer <key>` or `X-API-Key: <key>`; invalid/missing keys
# are rejected with 401 before any upstream connection.
GATEWAY_API_KEYS=

# Cost-aware routing (extension): when true, the provider chain is reordered
# cheapest-responsive-first using the per-model cost manifest.
COST_AWARE_ROUTING=false

# --- Primary provider (real, OpenAI-compatible) ---
# Examples:
#   OpenAI         https://api.openai.com/v1            (key sk-...)
#   Groq           https://api.groq.com/openai/v1       (key gsk_...)
#   OpenRouter     https://openrouter.ai/api/v1
#   DigitalOcean   https://inference.do-ai.run/v1       (key doo_...; model e.g. openai-gpt-oss-120b)
# Verified live against DigitalOcean Serverless Inference (gpt-oss-120b).
PRIMARY_BASE_URL=https://api.openai.com/v1
PRIMARY_API_KEY=sk-replace-me
PRIMARY_MODEL=

# --- Fallback provider ---
# Points at the local mock provider by default (deterministic fallback demo).
FALLBACK_BASE_URL=http://localhost:9100/v1
FALLBACK_API_KEY=mock-key
FALLBACK_MODEL=

# --- Routing / resilience tunables ---
MAX_FALLBACK_HOPS=2
REQUEST_DEADLINE_SECONDS=60
UPSTREAM_CONNECT_TIMEOUT=5
UPSTREAM_READ_TIMEOUT=60
